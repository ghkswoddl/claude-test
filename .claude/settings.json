{
  "autoUpdatesChannel": "latest",
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(npm test)",
      "Bash(npm test *)",
      "Bash(npx live-server)",
      "Bash(npx live-server *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Edit(~/.claude/settings.json)",
      "Write(~/.claude/settings.json)"
    ]
  }
}
